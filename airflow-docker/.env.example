# ---------------------------------------------------------------------------
# Template for airflow-docker/.env  ->  copy to .env and fill in.
#   cp .env.example .env
# Generate secrets with:
#   FERNET_KEY:                openssl rand -base64 32
#   AIRFLOW__API_AUTH__JWT...: openssl rand -hex 32
# ---------------------------------------------------------------------------

# Airflow core
AIRFLOW_UID=50000
FERNET_KEY=<run: openssl rand -base64 32>
AIRFLOW__API_AUTH__JWT_SECRET=<run: openssl rand -hex 32>

# Web UI admin account
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# Extra pip deps installed at container start (quick-dev only; prefer the Dockerfile)
_PIP_ADDITIONAL_REQUIREMENTS=astronomer-cosmos dbt-databricks dlt[databricks,sql_database] pandas psycopg2-binary sqlalchemy

# Paths mounted into containers (relative to airflow-docker/)
DBT_PROJECT_DIR=../dbt_project
DBT_PROFILES_DIR=../.dbt

# Source OLTP Postgres (Olist data) — read by the dlt EL script
SOURCE_POSTGRES_USER=olist
SOURCE_POSTGRES_PASSWORD=olist
SOURCE_POSTGRES_DB=olist
SOURCE_POSTGRES_PORT=5433

# dlt source DSN. Inside the Airflow worker the source Postgres is the compose
# service source-postgres:5432 (use localhost:5433 only for local host runs).
OLIST_SOURCE_DSN=postgresql://olist:olist@source-postgres:5432/olist

# Databricks (used by dbt via ~/.dbt/profiles.yml env_var lookups)
DBT_DATABRICKS_HOST=<dbc-xxxx.cloud.databricks.com>
DBT_DATABRICKS_HTTP_PATH=</sql/1.0/warehouses/xxxx>
DBT_DATABRICKS_TOKEN=<databricks personal access token>
DBT_DATABRICKS_CATALOG=olist
DBT_DATABRICKS_SCHEMA=analytics
